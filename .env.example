# ===========================================
# deployes - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# ⚠️  NEVER commit real secrets to git!
# ===========================================

# Database
POSTGRES_USER=deployes
POSTGRES_PASSWORD=CHANGE_ME_secure_password_here
DATABASE_URL=postgres://deployes:CHANGE_ME_secure_password_here@localhost:5432/deployes?sslmode=disable

# JWT Authentication (minimum 32 characters)
JWT_SECRET=CHANGE_ME_generate_a_random_32_char_key

# Encryption Key (exactly 32 characters for AES-256)
ENCRYPTION_KEY=CHANGE_ME_exactly_32_chars_long!

# Server
APP_PORT=8080
BASE_URL=http://localhost:8080

# CORS Allowed Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:4200
